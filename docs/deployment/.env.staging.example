# ZapCRM Staging Environment Variables
# Epic 2 (Integração WhatsApp↔CRM) Deployment
# Date: 2026-03-01

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

NODE_ENV=staging
PORT=3000
LOG_LEVEL=info

# ============================================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================================
# Get these from: https://supabase.com/dashboard → Project Settings → API

SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
SUPABASE_SERVICE_KEY=[YOUR-SERVICE-KEY-KEEP-SECRET]
SUPABASE_REALTIME_URL=wss://[YOUR-PROJECT-ID].supabase.co/realtime/v1

# ============================================================================
# WHATSAPP API CONFIGURATION (Required for webhook testing)
# ============================================================================
# Get these from: https://developers.facebook.com → Apps → Settings

WHATSAPP_API_URL=https://graph.instagram.com/v18.0
WHATSAPP_API_TOKEN=[YOUR-META-BUSINESS-TOKEN]
WHATSAPP_BUSINESS_ACCOUNT_ID=[YOUR-BUSINESS-ACCOUNT-ID]
WHATSAPP_PHONE_NUMBER_ID=[YOUR-PHONE-NUMBER-ID]

# Example values (DO NOT USE IN PRODUCTION):
# WHATSAPP_PHONE_NUMBER_ID=1234567890123456

# ============================================================================
# QSTASH CONFIGURATION (Required for message queuing)
# ============================================================================
# Get these from: https://console.upstash.com → QStash

QSTASH_TOKEN=[YOUR-QSTASH-API-TOKEN]
QSTASH_URL=https://qstash.io/v2

# ============================================================================
# FEATURE FLAGS (Optional, default: true)
# ============================================================================

ENABLE_WHATSAPP_BRIDGE=true
ENABLE_KEYWORD_MATCHING=true
ENABLE_AUTOMATION_TRIGGERS=true

# ============================================================================
# DEVELOPER/DEBUG (Optional)
# ============================================================================

DEBUG=zapccrm:*
VERBOSE_LOGGING=false

# ============================================================================
# NOTES FOR DEPLOYMENT TEAM
# ============================================================================

# 1. Copy this file to .env.staging in your deployment environment
# 2. Replace all [YOUR-*] placeholders with actual values
# 3. Verify all variables are set before deploying:
#    - SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_KEY
#    - WHATSAPP_API_TOKEN, WHATSAPP_PHONE_NUMBER_ID
#    - QSTASH_TOKEN
# 4. Test connection to each service before deploying:
#    curl -H "Authorization: Bearer $SUPABASE_SERVICE_KEY" "$SUPABASE_URL/rest/v1/"
# 5. Never commit this file to version control
# 6. Store secrets in your deployment platform's secrets manager (GitHub Secrets, AWS Secrets Manager, etc.)

# ============================================================================
# VALIDATION CHECKLIST
# ============================================================================

# [ ] SUPABASE_URL is reachable
# [ ] SUPABASE_ANON_KEY works (test with Supabase client)
# [ ] SUPABASE_SERVICE_KEY is valid (test with direct SQL)
# [ ] WHATSAPP_API_TOKEN is valid (test with Graph API)
# [ ] WHATSAPP_PHONE_NUMBER_ID exists in your account
# [ ] QSTASH_TOKEN is valid (test with QStash API)
# [ ] All required variables are set (no empty strings)
# [ ] Application starts without errors: npm start
# [ ] Webhook endpoint responds: POST /api/webhooks/whatsapp/contacts → 200
# [ ] Activity API responds: GET /api/activities → 200
# [ ] Keywords API responds: GET /api/keywords → 200
# [ ] Automations API responds: GET /api/automations → 200
